# ─── Supabase (scraper / jobs — clé service_role, NE JAMAIS committer la vraie valeur) ───
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ─── Scraper ───
# Délai (ms) entre deux requêtes vers Shotgun (rate limiting, cf. §10 du cahier des charges)
SCRAPE_DELAY_MS=1500
# User-Agent utilisé pour les requêtes
SCRAPE_USER_AGENT="ProspeGame/1.0 (veille perso; contact: you@example.com)"

# ─── Reporting ───
# Webhook (Slack/Discord/…) ou laisser vide pour un rapport écrit sur stdout / fichier
REPORT_WEBHOOK_URL=
